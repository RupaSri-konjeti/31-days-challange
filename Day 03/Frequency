//Frequency means no of times do the element occurs in the array
import java.util.Scanner;
    class Frequency{
        public static void main(String args[]){
        int arr[]={10,20,23,10,12};
        int count=0;
        for(int i=0;i<arr.length;i++)
        {
            if(arr[i]==10)
            {
            count++;
            }
        }
        System.out.println(count);
    }
}
