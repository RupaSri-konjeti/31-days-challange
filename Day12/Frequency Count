//Frequency Count of Array Elements 
import java.util.*;
class Main{
    public static void main(String args[])
    {
        int arr[]={23,45,67,45,67,45};
        HashMap<Integer,Integer>map=new HashMap<>();
        for(int num:arr){
        
        map.put(num,map.getOrDefault(num, 0)+1);
    }
    System.out.print(map);
}
}
