/*Selection Sort repeatedly finds the smallest element from the unsorted part of the array and places it at the correct position.

Idea
Find the smallest element.
Swap it with the first element.
Find the next smallest element.
Swap it with the second position.
Continue until the array is sorted
*/
import java.util.Scanner;
    class Main{
        public static void main(String args[])
        {
            Scanner sc=new Scanner(System.in);
            int n =sc.nextInt();
            int arr[]=new int[n];
            for(int i=0;i<n;i++)
            {
                arr[i]=sc.nextInt();
            }
            for(int i=0;i<n-1;i++)//neeed not to sort last element so n-1
            {
            int minIndex=i;//assuming first element is small number
            for( int j=i+1;j<n;j++)// i+1 bcs .we need to sort numbers after it
            {
                if(arr[j]<arr[minIndex])// inside the unsorted 
                {
                    minIndex=j; //changes minindex 0 to current number
                }
            }
            int temp=arr[i];
            arr[i]=arr[minIndex];
            arr[minIndex]=temp;
            }
            
            for(int i=0;i<n;i++)
            {
                System.out.print(arr[i] + " ");
            }
        }
    }
