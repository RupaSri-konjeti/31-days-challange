//binary search
import java.util.Scanner;
class Main{
    public static void main (String args[])
    {
       Scanner sc=new Scanner (System.in);
       System.out.println("enter number of elemnts");
       int n =sc.nextInt();
       System.out.println("enter the elemnts");
       int arr[]=new int[n];
       for(int i=0;i<n;i++)
       {
           arr[i]=sc.nextInt();
       }
       System.out.println("enter the target element");
       int target =sc.nextInt();
       //binary search
       int low=0;
       int high=n-1;//arr index starts from 0
       int found=-1; //intitially thinking no key in array
       
       while(high>=low)
       {
           int mid=(low+high)/2;
           
           
           if(arr[mid]==target)
           {
               found = mid;
               break;
           }
           
           if(arr[mid]<target )
           {
           low=mid+1;
           }
           else if (arr[mid]>target)
               {
                   high=mid-1;
               }
       }       
               if(found==-1)
               {
                   System.out.println("key not found");
               }
               else
               {
                   System.out.println("key found"+found);
               }
               
           }
       }
    
    
