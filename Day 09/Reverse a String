//reverse a string
import java.util.Scanner;
class Main {
public static void main(String args[]){
    String name ="rupasri";
    String reverse = " ";
    for(int i=name.length()-1;i>=0;i--)
    {
      reverse = reverse + name.charAt(i);
    }
    System.out.println("reverse string is "+reverse);
}
}
