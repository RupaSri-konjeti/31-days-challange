// Sum of Main Diagonal
import java.util.Scanner;
class Main{
    public static void main(String args[])
    {
        Scanner sc =new Scanner(System.in);
        int n[][]=new int[3][3];
        int sum=0;
        for(int i=0;i<n.length;i++)
        {
            for(int j=0;j<n.length;j++)
            {
                n[i][j]=sc.nextInt();
                
            }
        }
        for(int i=0;i<n.length;i++)
    {
        sum=sum+n[i][i];
    }
    System.out.print(sum);
    }
}
